{
    "name": "zerofyi/shipit",
    "description": "A zero-dependency dual-protocol deployment wizard for Hostinger shared hosting.",
    "keywords": ["laravel", "hostinger", "deployment", "git", "ssh"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "zerofyi",
            "homepage": "https://github.com/zerofyi"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Zerofyi\\ShipIt\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zerofyi\\ShipIt\\ShipItServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}